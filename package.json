{
    "name":  "animegate-translator",
    "version":  "1.0.64",
    "description":  "AnimeGate Translator - desktop app",
    "author":  "Adrian",
    "main":  "dist-electron/main.js",
    "scripts":  {
                    "dev":  "concurrently -k \"vite\" \"wait-on http://localhost:5173 \u0026\u0026 set ELECTRON_RUN_AS_NODE=\u0026\u0026 electron .\"",
                    "build":  "tsc -p tsconfig.electron.json \u0026\u0026 vite build \u0026\u0026 electron-builder",
                    "build:win":  "electron-builder --win",
                    "release:win":  "npm run build:renderer \u0026\u0026 npm run build:electron \u0026\u0026 electron-builder --win --publish always",
                    "build:renderer":  "vite build",
                    "build:electron":  "tsc -p tsconfig.electron.json",
                    "preview":  "vite preview",
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "verify:baseline":  "node scripts/pipeline-hardening-check.mjs \u0026\u0026 node scripts/series-projects-smoke.mjs \u0026\u0026 node scripts/archetype-ab-test.mjs",
                    "verify":  "npm run verify:baseline \u0026\u0026 npm run test \u0026\u0026 npm run build:renderer \u0026\u0026 npm run build:electron"
                },
    "devDependencies":  {
                            "@types/node":  "^20.11.0",
                            "@types/react":  "^18.2.48",
                            "@types/react-dom":  "^18.2.18",
                            "@vitejs/plugin-react":  "^4.2.1",
                            "concurrently":  "^8.2.2",
                            "electron":  "^29.0.0",
                            "electron-builder":  "^24.9.1",
                            "typescript":  "^5.3.3",
                            "vite":  "^5.0.12",
                            "vitest":  "^2.1.8",
                            "wait-on":  "^7.2.0"
                        },
    "dependencies":  {
                         "electron-updater":  "^6.3.9",
                         "react":  "^18.2.0",
                         "react-dom":  "^18.2.0"
                     },
    "build":  {
                  "appId":  "com.animegate.translator",
                  "productName":  "AnimeGate Translator",
                  "artifactName":  "AnimeGate-Translator-Setup.exe",
                  "directories":  {
                                      "output":  "release"
                                  },
                  "files":  [
                                "dist/**/*",
                                "dist-electron/**/*"
                            ],
                  "extraResources":  [
                                         {
                                             "from":  "ffmpeg",
                                             "to":  "ffmpeg",
                                             "filter":  [
                                                            "**/*"
                                                        ]
                                         }
                                     ],
                  "win":  {
                              "target":  "nsis",
                              "signAndEditExecutable":  false
                          },
                  "publish":  [
                                  {
                                      "provider":  "github",
                                      "owner":  "anikronika-svg",
                                      "repo":  "T-umacz-AnimeGate",
                                      "releaseType":  "release"
                                  }
                              ],
                  "nsis":  {
                               "oneClick":  false,
                               "perMachine":  true,
                               "allowElevation":  true,
                               "createDesktopShortcut":  true,
                               "createStartMenuShortcut":  true,
                               "shortcutName":  "AnimeGate Translator",
                               "displayLanguageSelector":  false
                           }
              }
}
